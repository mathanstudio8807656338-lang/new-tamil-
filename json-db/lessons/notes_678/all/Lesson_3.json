    "quiz": {
        "questions": [
            { "question": "எழுத்துகள் தொடர்ந்து வந்து பொருள் தருவது ______ எனப்படும்.", "options": ["வாக்கியம்", "சொல்", "பந்தி", "சார்பெழுத்து"], "answer": 1, "explanation": "தனித்தோ அல்லது பிற எழுத்துகளுடன் தொடர்ந்தோ பொருள் தருவது சொல் எனப்படும்." },
            { "question": "சொற்கள் இலக்கண அடிப்படையில் எத்தனை வகைப்படும்?", "options": ["3", "4", "5", "6"], "answer": 1, "explanation": "பெயர், வினை, இடை, உரி என நான்கு வகைப்படும்." },
            { "question": "ஒன்றன் பெயரைக் குறிக்கும் சொல் எது?", "options": ["பெயர்ச்சொல்", "வினைச்சொல்", "இடைச்சொல்", "உரிச்சொல்"], "answer": 0, "explanation": "எ.கா: பாரதி, பள்ளி." },
            { "question": "ஒரு செயலைக் குறிக்கும் சொல் எது?", "options": ["பெயர்ச்சொல்", "வினைச்சொல்", "இடைச்சொல்", "உரிச்சொல்"], "answer": 1, "explanation": "எ.கா: வந்தான், ஓடினான்." },
            { "question": "பெயர்ச்சொல்லையும் வினைச்சொல்லையும் சார்ந்து வந்து, தனித்து இயங்காத சொல் எது?", "options": ["பெயர்ச்சொல்", "வினைச்சொல்", "இடைச்சொல்", "உரிச்சொல்"], "answer": 2, "explanation": "இடைச்சொல் (எ.கா: உம், மற்று)." },
            { "question": "பெயர் / வினையின் தன்மையை மிகுதிப்படுத்த வருவது ______.", "options": ["பெயர்ச்சொல்", "வினைச்சொல்", "இடைச்சொல்", "உரிச்சொல்"], "answer": 3, "explanation": "உரிச்சொல் (எ.கா: மாநகரம், சாலப்பேசினான்)." },
            { "question": " 'திருக்குறளை' என்பதில் உள்ள 'ஐ' என்பது எவ்வகைச் சொல்?", "options": ["பெயர்ச்சொல்", "வினைச்சொல்", "இடைச்சொல்", "உரிச்சொல்"], "answer": 2, "explanation": "ஐ என்பது ஒரு இடைச்சொல்." },
            { "question": "பெயர்ச்சொல் மொத்தம் எத்தனை வகைப்படும்?", "options": ["4", "5", "6", "8"], "answer": 2, "explanation": "பொருள், இடம், காலம், சினை, பண்பு, தொழில் என 6 வகைப்படும்." },
            { "question": "மரம், செடி, மயில், புத்தகம் ஆகியவை எவ்வகை பெயர்?", "options": ["பொருட்பெயர்", "இடப்பெயர்", "சினைப்பெயர்", "பண்புப்பெயர்"], "answer": 0, "explanation": "பொருளின் பெயரைக் குறிப்பதால் பொருட்பெயர்." },
            { "question": "சென்னை, பள்ளி, தெரு ஆகியவை எவ்வகை பெயர்?", "options": ["பொருட்பெயர்", "இடப்பெயர்", "காலப்பெயர்", "பண்புப்பெயர்"], "answer": 1, "explanation": "இடத்தைக் குறிப்பதால் இடப்பெயர்." },
            { "question": "நிமிடம், நாள், மாதம், சித்திரை ஆகியவை எவ்வகை பெயர்?", "options": ["பொருட்பெயர்", "இடப்பெயர்", "காலப்பெயர்", "தொழிற்பெயர்"], "answer": 2, "explanation": "காலத்தைக் குறிப்பதால் காலப்பெயர்." },
            { "question": "கண், கை, இலை, கிளை ஆகியவை எவ்வகை பெயர்?", "options": ["பொருட்பெயர்", "சினைப்பெயர்", "பண்புப்பெயர்", "தொழிற்பெயர்"], "answer": 1, "explanation": "சினை என்றால் உறுப்பு என்று பொருள்." },
            { "question": "நன்மை, மென்மை, வட்டம், சதுரம் ஆகியவை எவ்வகை பெயர்?", "options": ["பண்புப்பெயர்", "தொழிற்பெயர்", "சினைப்பெயர்", "காலப்பெயர்"], "answer": 0, "explanation": "பண்பைக் குறிப்பதால் பண்புப்பெயர்." },
            { "question": "ஆடுதல், பாடுதல், படித்தல் ஆகியவை எவ்வகை பெயர்?", "options": ["பண்புப்பெயர்", "தொழிற்பெயர்", "சினைப்பெயர்", "காலப்பெயர்"], "answer": 1, "explanation": "தொழிலைக் குறிப்பதால் தொழிற்பெயர்." },
            { "question": "நம் முன்னோர் காரணம் கருதாமல் சில பொருள்களுக்கு இட்ட பெயர்கள் ______.", "options": ["காரணப்பெயர்", "இடுகுறிப்பெயர்", "சினைப்பெயர்", "பண்புப்பெயர்"], "answer": 1, "explanation": "இடுகுறிப்பெயர் (எ.கா: மண், மரம்)." },
            { "question": "இடுகுறிப் பொதுப்பெயர் எது?", "options": ["மரம்", "மா", "வாழை", "கருவேலங்காடு"], "answer": 0, "explanation": "மரம் என்பது உலகிலுள்ள எல்லா மரங்களுக்கும் பொதுவான பெயர்." },
            { "question": "இடுகுறிச் சிறப்புப்பெயர் எது?", "options": ["மரம்", "காடு", "மா", "விலங்கு"], "answer": 2, "explanation": "மா என்பது ஒரு குறிப்பிட்ட வகை மரத்தைச் சிறப்பாகக் குறிப்பது." },
            { "question": "காரணம் கருதி இட்ட பெயர்கள் ______.", "options": ["காரணப்பெயர்", "இடுகுறிப்பெயர்", "சினைப்பெயர்", "பெயர்ச்சொல்"], "answer": 0, "explanation": "எ.கா: நாற்காலி - நான்கு கால்கள் உள்ளதால்." },
            { "question": "காரணப் பொதுப்பெயர் எது?", "options": ["பறவை", "மரங்கொத்தி", "வளையல்", "வானூர்தி"], "answer": 0, "explanation": "பறப்பதால் 'பறவை' - இது எல்லாப் பறவைகளுக்கும் பொது." },
            { "question": "காரணச் சிறப்புப்பெயர் எது?", "options": ["பறவை", "அணி", "மரங்கொத்தி", "மனிதன்"], "answer": 2, "explanation": "பறவைகளுள் மரத்தைக் கொத்துவதை மட்டும் சிறப்பாகக் குறிப்பது." },
            { "question": "அணி என்பதன் பொருள் யாது?", "options": ["பாட்டு", "அழகு", "உச்சரிப்பு", "இலக்கணம்"], "answer": 1, "explanation": "செய்யுளுக்கு அழகு சேர்ப்பது அணி." },
            { "question": "பொருளின் இயல்பை உள்ளது உள்ளபடியே அழகுடன் கூறுவது ______.", "options": ["உயர்வு நவிற்சி", "இயல்பு நவிற்சி", "உவமை", "பண்பு"], "answer": 1, "explanation": "இயல்பு நவிற்சி அணி (எ.கா: தோட்டத்தில் மேயுது வெள்ளைப்பசு)." },
            { "question": "பொருளின் இயல்பை மிகைப்படுத்தி மிகைப்படுத்தி அழகுடன் கூறுவது ______.", "options": ["இயல்பு நவிற்சி", "உயர்வு நவிற்சி", "உருவகம்", "மறை"], "answer": 1, "explanation": "உயர்வு நவிற்சி அணி." },
            { "question": "தாலாட்டுப் பாடலில் குழந்தையை மிகைப்படுத்திக் கூறுவது எவ்வகை அணி?", "options": ["இயல்பு நவிற்சி", "உயர்வு நவிற்சி", "உவமை", "உருவகம்"], "answer": 1, "explanation": "தாலாட்டில் குழந்தையை உயர்த்திப் புகழ்வது உயர்வு நவிற்சி." },
            { "question": " 'சாலப்பேசினான்' என்பதில் 'சால' என்பது எவ்வகைச் சொல்?", "options": ["பெயர்", "வினை", "இடை", "உரி"], "answer": 3, "explanation": "உரிச்சொல் மிகுதியாகப் பேசுவதைக் குறிக்கிறது." },
            { "question": "மாநகரம் என்பதில் 'மா' என்பது எவ்வகைச் சொல்?", "options": ["பெயர்", "வினை", "இடை", "உரி"], "answer": 3, "explanation": "மா என்பது பெரிய என்னும் பொருள்படும் உரிச்சொல்." },
            { "question": "சித்திரை என்பது எவ்வகை பெயர்ச்சொல்?", "options": ["இடப்பெயர்", "காலப்பெயர்", "சினைப்பெயர்", "பொருட்பெயர்"], "answer": 1, "explanation": "சித்திரை ஒரு மாதத்தின் (காலத்தின்) பெயர்." },
            { "question": "கை என்பது எவ்வகை பெயர்ச்சொல்?", "options": ["பொருட்பெயர்", "காலப்பெயர்", "சினைப்பெயர்", "இடப்பெயர்"], "answer": 2, "explanation": "கை என்பது உடலின் ஒரு உறுப்பு (சினை)." },
            { "question": "வளையல் என்பது எவ்வகை பெயர்?", "options": ["இடுகுறிப்பெயர்", "காரணப்பெயர்", "சினைப்பெயர்", "குணப்பெயர்"], "answer": 1, "explanation": "வளைந்து இருப்பதால் இது காரணப்பெயர்." },
            { "question": "தவறான இணையைக் கண்டறிக.", "options": ["இடைச்சொல் - மற்று", "உரிச்சொல் - சால", "வினைச்சொல் - வந்தான்", "பெயர்ச்சொல் - நடந்தான்"], "answer": 3, "explanation": "'நடந்தான்' என்பது வினைச்சொல். பெயர்ச்சொல் அல்ல." }
        ]
    }
}
